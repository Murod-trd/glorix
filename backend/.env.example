# Glorix v7 — Environment Configuration
# Скопируйте в .env и заполните значения

# ── Ollama (локальная LLM) ──────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_TIMEOUT=60

# ── Qdrant (векторная БД) ───────────────────────────────
# Для ноутбука проще начать с embedded mode. Для Docker — 0 и внешний Qdrant.
USE_EMBEDDED_QDRANT=1
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=tnved_codes
QDRANT_STORAGE_PATH=./qdrant_storage

# ── Данные ─────────────────────────────────────────────
DATA_DIR=./data
EXCEL_DIR=./data/excel
PDF_DIR=./data/pdf

# ── API ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
REBUILD_TOKEN=change-this-token
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Классификатор ───────────────────────────────────────
# MIN_CONFIDENCE_TO_ANSWER=0.45  # переопределить config.py
# MIN_EVIDENCE_SCORE=0.30
