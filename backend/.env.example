# Glorix v7 — Environment Configuration
# Скопируйте в .env и заполните значения

# ── Ollama (локальная LLM) ──────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_TIMEOUT=60

# ── Qdrant (векторная БД) ───────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=tnved_codes

# ── Данные ─────────────────────────────────────────────
EXCEL_DB_PATH=./data/tnved_codes.xlsx
PDF_DOCS_DIR=./data/pdf_docs/

# ── API ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# ── Классификатор ───────────────────────────────────────
# MIN_CONFIDENCE_TO_ANSWER=0.45  # переопределить config.py
# MIN_EVIDENCE_SCORE=0.30

# ── Document AI job engine ─────────────────────────────
# Persistent job storage OUTSIDE the repository (recommended on the laptop):
#   Windows example: DOC_JOBS_DIR=G:\GLORIX_SERVER\jobs
# If empty, defaults to <DATA_DIR>/doc_jobs (DATA_DIR is git-ignored).
DOC_JOBS_DIR=
# Cold-start safe default: 1 real classification at a time until models are warm.
# The engine also serializes the FIRST classify behind a warmup lock, then honors
# this value for controlled concurrency.
DOC_AI_CONCURRENCY=1
# Legacy global LLM-normalization flag. Bulk jobs are deterministic-only by default;
# per-job LLM normalization is opt-in via the request field use_llm_normalizer=true.
DOC_AI_USE_LLM=0
# Strict per-row timeouts (seconds). Rows never stay stuck; jobs always finish.
DOC_AI_NORMALIZE_TIMEOUT_SEC=20
DOC_AI_CLASSIFY_TIMEOUT_SEC=90

# ── Internet-assisted evidence (OFF unless configured) ─
# Provider empty ⇒ web_search: not_configured (no web calls, nothing faked).
WEB_SEARCH_PROVIDER=
WEB_SEARCH_API_KEY=
WEB_SEARCH_TIMEOUT=8
