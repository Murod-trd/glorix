{
  "rewrites": [
    {
      "source": "/api/tnved-ai/:action",
      "destination": "/api/tnved-ai?action=:action"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/*.js": {
      "includeFiles": "api/_data/**"
    }
  }
}
