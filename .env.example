# ─────────────────────────────────────────────────────────────
# Glorix environment — EXAMPLE / placeholders only.
# Copy to `.env` and fill real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# Database connection string.
# DEV (zero-config, default schema provider = sqlite):
DATABASE_URL="file:./dev.db"
# PRODUCTION: use an external PostgreSQL and switch the provider in
# prisma/schema.prisma to "postgresql". Example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/glorix?schema=public"

# JWT signing secret for the auth foundation.
# MUST be a long, random, secret value in production. Example to generate:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-secure-random-secret"

# Frontend feature flag for real auth.
# false (default) = existing demo/localStorage account flow (safe).
# true            = frontend may call /api/auth/* endpoints.
VITE_USE_REAL_AUTH=false
