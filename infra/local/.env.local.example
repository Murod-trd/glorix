# GLORIX Local Server Hub — LOCAL env EXAMPLE (placeholders only).
# Copy to infra/local/.env.local and edit. NEVER commit .env.local.

# Gateway (public via tunnel) and internal service ports
GLORIX_LOCAL_GATEWAY_PORT=8787
TNVED_BACKEND_PORT=8000
QDRANT_PORT=6333

# Ollama on the Windows host (reached from containers)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M

# Public tunnel URL (filled after you start a named Cloudflare Tunnel). No trailing slash.
GLORIX_PUBLIC_TUNNEL_URL=

# Proxy timeout used by the Vercel /api/tnved-ai proxy
TNVED_AI_TIMEOUT_MS=8000

# PRODUCTION mode for the AI backend — mocks MUST be off on the laptop
MOCK_EMBEDDER=0
MOCK_LLM=0
